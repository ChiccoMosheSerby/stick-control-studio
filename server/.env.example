MONGO_URI=mongodb://127.0.0.1:27017/stickcontrol
PORT=4001

# Auth — required. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Optional SMTP for password-reset emails. If unset, the reset link is logged to
# the server console instead (fine for development).
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# APP_URL=
